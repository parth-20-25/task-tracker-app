{
  "name": "tasktracker",
  "version": "1.0.0",
  "description": "TaskTracker - Full-stack application with Backend, Python Service, and Frontend",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "python-service"
  ],
  "scripts": {
    "workspace:backend": "cd backend && npm start",
    "workspace:frontend": "cd frontend && npm run build",
    "workspace:python": "cd python-service && uvicorn app.main:app --host 0.0.0.0 --port 8000"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}